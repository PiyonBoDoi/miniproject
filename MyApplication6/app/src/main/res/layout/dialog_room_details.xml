<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDetId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mã phòng: 101"
            android:textColor="#6200EE"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tên phòng: Phòng 101"
            android:textColor="#212121"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Giá thuê: 1,500,000 VNĐ"
            android:textColor="#616161"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvDetStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tình trạng: Còn trống"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="italic" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"
            android:background="#EEEEEE" />

        <LinearLayout
            android:id="@+id/layoutTenantDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN NGƯỜI THUÊ"
                android:textColor="#6200EE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetTenant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Người thuê: Nguyễn Văn A"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvDetPhone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Số điện thoại: 0987654321"
                    android:textColor="#212121"
                    android:textSize="16sp"/>

                <ImageButton
                    android:id="@+id/btnCall"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_call"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Gọi điện"
                    app:tint="#6200EE"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetBirthDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ngày sinh: 01/01/2000"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDetGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giới tính: Nam"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDetAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Địa chỉ: Hà Nội"
                android:textColor="#212121"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDetRentalTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thời gian thuê: 12 tháng"
                android:textColor="#212121"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>